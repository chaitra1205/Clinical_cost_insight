# Copy to backend/.env for local Flask (never commit .env).

# --- MongoDB Atlas ---
# MONGO_URI=mongodb+srv://...
# MONGO_DB_NAME=healthcare_platform

# --- Flask ---
# SECRET_KEY=long-random-string

# --- CORS (Render) ---
# FRONTEND_ORIGINS=https://your-app.vercel.app

# --- Resend API (booking emails + /test-email) ---
# Sign up at https://resend.com → Dashboard → API Keys → Create.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# From address — use onboarding@resend.dev for testing.
# For production, verify your own domain in Resend and use that.
# RESEND_FROM=ClinixCompare <onboarding@resend.dev>
#
# Every booking email is sent TO this address.
# Defaults to siddharthgaddam34@gmail.com if unset.
# BOOKING_EMAIL_TO=siddharthgaddam34@gmail.com
#
# Optional: prefix [TEST MODE] on subjects when true. On Render, omit for false.
# EMAIL_TEST_MODE=false

# --- Frontend (Vercel build) ---
# CC_API_BASE_URL=https://your-render-service.onrender.com
